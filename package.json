{
  "name": "n8n-nodes-wiso-frog",
  "version": "0.1.0",
  "description": "n8n community node for Wiso API access",
  "author": {
    "name": "Leithon Gauci",
    "email": "lgauci@airosoftware.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://bitbucket.org/airomt/wiso-n8n.git"
  },
  "engines": {
    "node": ">=22 <23"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "wiso",
    "api"
  ],
  "scripts": {
    "dev": "n8n-node dev",
    "build": "n8n-node build",
    "build:watch": "n8n-node build --watch",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/WisoFrogApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/WisoFrog/WisoFrog.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@n8n/node-cli": "^0.32.1",
    "n8n-workflow": "*",
    "typescript": "^5.8.3"
  }
}
